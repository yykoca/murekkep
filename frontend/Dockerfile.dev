# 1. Use a lightweight Node.js image
FROM node:20-alpine

# 2. Set the working directory inside the container
WORKDIR /app

# 3. Copy only the package files first
# This keeps the npm install layer cached even when application code changes
COPY package*.json ./

# 4. Install dependencies
RUN npm install --legacy-peer-deps

# 5. Copy the rest of the project files
COPY . .

# 6. Expose the port so Angular is reachable from outside the container
EXPOSE 4200

# 7. Start the Angular CLI
# --host 0.0.0.0: required for access from outside Docker
# --poll 2000: helps Docker, especially on Windows and Mac, detect file changes reliably
CMD ["npx", "ng", "serve", "--host", "0.0.0.0", "--poll", "2000"]
